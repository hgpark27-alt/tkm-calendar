{
  "name": "tkm-calendar",
  "version": "1.2.2",
  "description": "TKM Calendar — shared team calendar widget",
  "main": "main/index.js",
  "author": "Hansol IONES",
  "private": true,
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.hansolliones.tkmcalendar",
    "productName": "TKM Calendar",
    "compression": "maximum",
    "files": [
      "main/**/*",
      "frontend/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "publish": {
      "provider": "github",
      "owner": "hgpark27-alt",
      "repo": "tkm-calendar"
    }
  },
  "devDependencies": {
    "electron": "^31.3.1",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "electron-updater": "^6.3.0"
  }
}
